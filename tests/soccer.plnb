   "source": [
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.colors as mcolors\n",
    "\n",
    "# Filter countries that have played at least 100 matches\n",
    "filtered_countries = country_stats[country_stats['total_matches'] >= 100].copy()\n",
    "\n",
    "# Calculate win fractions, handling potential division by zero\n",
    "# If a team has played 0 home or away matches, their win fraction for that category is 0.\n",
    "filtered_countries['win_home_fraction'] = filtered_countries.apply(\n",
    "    lambda row: row['wins_home'] / row['total_matches_home'] if row['total_matches_home'] > 0 else 0,\n",
    "    axis=1\n",
    ")\n",
    "filtered_countries['win_away_fraction'] = filtered_countries.apply(\n",
    "    lambda row: row['wins_away'] / row['total_matches_away'] if row['total_matches_away'] > 0 else 0,\n",
    "    axis=1\n",
    ")\n",
    "\n",
    "# Calculate the difference between home and away win fractions for coloring\n",
    "# Positive values mean more likely to win at home, negative means more likely to win away.\n",
    "filtered_countries['win_diff'] = filtered_countries['win_home_fraction'] - filtered_countries['win_away_fraction']\n",
    "\n",
    "# Define a custom colormap to match the requirements:\n",
    "# Green for more likely to win away (negative win_diff)\n",
    "# Gray for equally likely (win_diff near 0)\n",
    "# Red for more likely to win at home (positive win_diff)\n",
    "colors = [\"green\", \"gray\", \"red\"]\n",
    "# Create a normalized colormap where -1 maps to green, 0 maps to gray, and 1 maps to red.\n",
    "cmap_name = 'home_away_advantage_cmap'\n",
    "cm = mcolors.LinearSegmentedColormap.from_list(\n",
    "    cmap_name, colors, N=256\n",
    ")\n",
    "\n",
    "# Create the scatterplot\n",
    "plt.figure(figsize=(12, 8))\n",
    "scatter = plt.scatter(\n",
    "    filtered_countries['win_away_fraction'],\n",
    "    filtered_countries['win_home_fraction'],\n",
    "    c=filtered_countries['win_diff'],  # Color by the difference\n",
    "    cmap=cm,                           # Use the custom colormap\n",
    "    vmin=-1,                           # Min value for color scaling (max away advantage)\n",
    "    vmax=1,                            # Max value for color scaling (max home advantage)\n",
    "    s=100,                             # Size of points\n",
    "    alpha=0.8,\n",
    "    edgecolors='w', linewidths=0.5\n",
    ")\n",
    "\n",
    "# Add country names as annotations to the points\n",
    "# This can make the plot crowded, consider removing for very large datasets\n",
    "for i, row in filtered_countries.iterrows():\n",
    "    plt.annotate(\n",
    "        row['country'],\n",
    "        (row['win_away_fraction'], row['win_home_fraction']),\n",
    "        textcoords=\"offset points\",\n",
    "        xytext=(5,5),\n",
    "        ha='left',\n",
    "        fontsize=8\n",
    "    )\n",
    "\n",
    "# Add a diagonal line for reference where home win fraction equals away win fraction\n",
    "plt.plot([0, 1], [0, 1], 'k--', alpha=0.5, label='Home Win % = Away Win %')\n",
    "\n",
    "# Set plot title and labels\n",
    "plt.title('Home Win Fraction vs. Away Win Fraction (Countries with >= 100 Matches)', fontsize=16)\n",
    "plt.xlabel('Win Away Fraction', fontsize=12)\n",
    "plt.ylabel('Win Home Fraction', fontsize=12)\n",
    "plt.grid(True, linestyle='--', alpha=0.6)\n",
    "\n",
    "# Set axis limits for better visualization\n",
    "plt.xlim(-0.05, 1.05)\n",
    "plt.ylim(-0.05, 1.05)\n",
    "\n",
    "# Add a color bar to explain the color mapping\n",
    "cbar = plt.colorbar(scatter)\n",
    "cbar.set_label('Home Win Fraction - Away Win Fraction', fontsize=12)\n",
    "# Customize color bar ticks and labels for clarity\n",
    "cbar.set_ticks([-1, -0.5, 0, 0.5, 1])\n",
    "cbar.set_ticklabels(['Strong Away Advantage', '', 'Equally Likely', '', 'Strong Home Advantage'])\n",
    "\n",
    "plt.legend()\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
