        "source": "import pandas as pd\n\n# Create a small country_stats DataFrame with 4 countries\n# Each country has known home/away wins, losses, ties, and totals\ndata = {\n    'country': ['Brazil', 'Germany', 'France', 'Argentina'],\n    'wins_home': [8, 6, 5, 7],\n    'losses_home': [1, 2, 2, 1],\n    'ties_home': [1, 2, 3, 2],\n    'total_matches_home': [10, 10, 10, 10],\n    'wins_away': [4, 5, 2, 3],\n    'losses_away': [3, 2, 4, 3],\n    'ties_away': [3, 3, 4, 4],\n    'total_matches_away': [10, 10, 10, 10],\n    'total_wins': [12, 11, 7, 10],\n    'total_losses': [4, 4, 6, 4],\n    'total_ties': [4, 5, 7, 6],\n    'total_matches': [20, 20, 20, 20],\n}\n\ncountry_stats = pd.DataFrame(data)\n\nprint(\"country_stats (setup):\")\nprint(country_stats)\nprint(\"\\nExpected away_win_ratio:\")\nfor _, row in country_stats.iterrows():\n    print(f\"  {row['country']}: away={row['wins_away']/row['total_matches_away']:.2f}, home={row['wins_home']/row['total_matches_home']:.2f}\")"
