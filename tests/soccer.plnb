        "source": "expected_total_goals_df = df['home_score'].sum() + df['away_score'].sum()\nactual_total_goals_country_goals = country_goals['goals_scored_home'].sum() + country_goals['goals_scored_away'].sum()\n\nassert expected_total_goals_df == actual_total_goals_country_goals, \\\n    f\"Expected total goals from df ({expected_total_goals_df}) does not match total goals from country_goals ({actual_total_goals_country_goals})\"\n\nprint(\"Total goals assertion passed.\")"
       }
