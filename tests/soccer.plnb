   "source": [
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# Merge country_goals with country_stats to get all necessary columns\n",
    "# An inner merge is suitable as we will filter for countries with sufficient total matches.\n",
    "merged_stats_goals = pd.merge(country_stats, country_goals, on='country', how='inner')\n",
    "\n",
    "# Filter countries that have played at least 100 matches, similar to the previous plot\n",
    "filtered_goal_countries = merged_stats_goals[merged_stats_goals['total_matches'] >= 100].copy()\n",
    "\n",
    "# Calculate goals scored per home match and per away match\n",
    "# Handle potential division by zero: if total_matches_home/away is 0, goals_scored_home/away must also be 0, so the fraction is 0.\n",
    "filtered_goal_countries['goals_per_home_match'] = filtered_goal_countries.apply(\n",
    "    lambda row: row['goals_scored_home'] / row['total_matches_home'] if row['total_matches_home'] > 0 else 0,\n",
    "    axis=1\n",
    ")\n",
    "filtered_goal_countries['goals_per_away_match'] = filtered_goal_countries.apply(\n",
    "    lambda row: row['goals_scored_away'] / row['total_matches_away'] if row['total_matches_away'] > 0 else 0,\n",
    "    axis=1\n",
    ")\n",
    "\n",
    "# Calculate the difference between home and away goals per match for coloring\n",
    "# Positive values mean more goals scored per home match, negative means more per away match.\n",
    "filtered_goal_countries['goal_diff'] = filtered_goal_countries['goals_per_home_match'] - filtered_goal_countries['goals_per_away_match']\n",
    "\n",
    "# Determine appropriate vmin/vmax for the color scale to center gray at 0\n",
    "# The colormap 'cm' was defined in a previous cell to map to green, gray, red.\n",
    "# We need to set vmin and vmax for the scatter plot's color argument (c) such that\n",
    "# 0 maps to the center (gray), negative values to green, and positive to red.\n",
    "max_abs_goal_diff = max(abs(filtered_goal_countries['goal_diff'].min()), abs(filtered_goal_countries['goal_diff'].max()))\n",
    "color_vmin = -max_abs_goal_diff\n",
    "color_vmax = max_abs_goal_diff\n",
    "\n",
    "# Create the scatterplot\n",
    "plt.figure(figsize=(12, 8))\n",
    "scatter_goals = plt.scatter(\n",
    "    filtered_goal_countries['goals_per_away_match'],\n",
    "    filtered_goal_countries['goals_per_home_match'],\n",
    "    c=filtered_goal_countries['goal_diff'],  # Color by the difference\n",
    "    cmap=cm,                                # Use the custom colormap from the previous cell\n",
    "    vmin=color_vmin,                        # Min value for color scaling (max away advantage)\n",
    "    vmax=color_vmax,                        # Max value for color scaling (max home advantage)\n",
    "    s=100,                                  # Size of points\n",
    "    alpha=0.8,\n",
    "    edgecolors='w', linewidths=0.5\n",
    ")\n",
    "\n",
    "# Add country names as annotations to the points\n",
    "for i, row in filtered_goal_countries.iterrows():\n",
    "    plt.annotate(\n",
    "        row['country'],\n",
    "        (row['goals_per_away_match'], row['goals_per_home_match']),\n",
    "        textcoords=\"offset points\",\n",
    "        xytext=(5,5),\n",
    "        ha='left',\n",
    "        fontsize=8\n",
    "    )\n",
    "\n",
    "# Determine axis limits for better visualization and for the diagonal line\n",
    "max_goal_fraction_val = max(filtered_goal_countries['goals_per_home_match'].max(), filtered_goal_countries['goals_per_away_match'].max())\n",
    "plot_limit = max_goal_fraction_val * 1.1 # Add a small buffer to the max value\n",
    "\n",
    "# Add a diagonal line for reference where home goals/match equals away goals/match\n",
    "plt.plot([0, plot_limit], [0, plot_limit], 'k--', alpha=0.5, label='Home Goals/Match = Away Goals/Match')\n",
    "\n",
    "# Set plot title and labels\n",
    "plt.title('Goals Scored per Home Match vs. Goals Scored per Away Match (Countries with >= 100 Matches)', fontsize=16)\n",
    "plt.xlabel('Goals Scored per Away Match', fontsize=12)\n",
    "plt.ylabel('Goals Scored per Home Match', fontsize=12)\n",
    "plt.grid(True, linestyle='--', alpha=0.6)\n",
    "\n",
    "# Set axis limits\n",
    "plt.xlim(-0.05, plot_limit)\n",
    "plt.ylim(-0.05, plot_limit)\n",
    "\n",
    "# Add a color bar to explain the color mapping\n",
    "cbar_goals = plt.colorbar(scatter_goals)\n",
    "cbar_goals.set_label('Goals per Home Match - Goals per Away Match', fontsize=12)\n",
    "# Customize color bar ticks and labels for clarity\n",
    "cbar_goals.set_ticks([round(color_vmin, 2), 0, round(color_vmax, 2)])\n",
    "cbar_goals.set_ticklabels([\n",
    "    f'Strong Away Advantage ({round(color_vmin, 2)})',\n",
    "    'Equally Likely (0)',\n",
    "    f'Strong Home Advantage ({round(color_vmax, 2)})'\n",
    "])\n",
    "\n",
    "plt.legend()\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  }
 ],
