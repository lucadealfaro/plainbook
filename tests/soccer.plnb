   "source": [
    "# Plot for the 30 countries that played the most matches, the ratio of wins away to total away matches, and wins home to total home matches.  In  other words, the fractions of away and home wins. Sort this in descending fraction of away wins. \n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# Select the top 30 countries by total matches played\n",
    "top_30_countries = country_stats.head(30).copy()\n",
    "\n",
    "# Calculate the win ratios for home and away matches\n",
    "top_30_countries['win_ratio_away'] = top_30_countries['wins_away'] / top_30_countries['total_matches_away']\n",
    "top_30_countries['win_ratio_home'] = top_30_countries['wins_home'] / top_30_countries['total_matches_home']\n",
    "\n",
    "# Sort the DataFrame by the away win ratio in descending order\n",
    "sorted_top_30 = top_30_countries.sort_values('win_ratio_away', ascending=False)\n",
    "\n",
    "# Set the country name as the index for plotting\n",
    "plot_data = sorted_top_30.set_index('country')\n",
    "\n",
    "# Create the bar plot\n",
    "ax = plot_data[['win_ratio_home', 'win_ratio_away']].plot(kind='bar', figsize=(18, 8))\n",
    "\n",
    "# Set plot title and labels\n",
    "ax.set_title('Home vs. Away Win Ratios for Top 30 Countries by Matches Played', fontsize=16)\n",
    "ax.set_xlabel('Country', fontsize=12)\n",
    "ax.set_ylabel('Win Ratio', fontsize=12)\n",
    "ax.legend(['Home Win Ratio', 'Away Win Ratio'])\n",
    "\n",
    "# Rotate x-axis labels for better readability\n",
    "plt.xticks(rotation=45, ha='right')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
