        "source": "import pandas as pd\nimport io\n\n# Setup a small, controlled dataset for testing\n# This dataset is designed to specifically test the logic of the target cell:\n# - Italy: Plays more games at home (2) than away (1).\n# - Spain: Plays more games away (2) than at home (1).\n# - Italy: Wins more games at home (2) than away (0).\ndata = \"\"\"date,home_team,away_team,home_score,away_score,tournament,city,country,neutral\n2023-01-01,Italy,Spain,2,1,Friendly,Rome,Italy,False\n2023-01-02,Italy,France,3,0,Friendly,Milan,Italy,False\n2023-01-03,Spain,Italy,1,0,Friendly,Madrid,Spain,False\n2023-01-04,France,Spain,2,1,Friendly,Paris,France,False\n\"\"\"\n\n# Create the DataFrame\ndf = pd.read_csv(io.StringIO(data))\n\n# Display the sample dataset\nprint(\"Sample football dataset:\")\nprint(df.to_string())"
