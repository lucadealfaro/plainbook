   "source": [
    "home_goals = df.groupby('home_team')['home_score'].sum()\n",
    "away_goals = df.groupby('away_team')['away_score'].sum()\n",
    "\n",
    "country_goals = pd.DataFrame({\n",
    "    'goals_scored_home': home_goals,\n",
    "    'goals_scored_away': away_goals\n",
    "})\n",
    "\n",
    "country_goals = country_goals.fillna(0).astype(int)\n",
    "\n",
    "country_goals = country_goals.reset_index().rename(columns={'index': 'country'})\n",
    "\n",
    "country_goals"
   ]
  },
