     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "# Determine match outcomes from the home team's perspective for efficient aggregation\n",
    "df['home_win'] = df['home_score'] > df['away_score']\n",
    "df['away_win'] = df['home_score'] < df['away_score']\n",
    "df['tie'] = df['home_score'] == df['away_score']\n",
    "\n",
    "# Aggregate stats for games played at home for each team\n",
    "home_stats = df.groupby('home_team').agg(\n",
    "    wins_home=('home_win', 'sum'),\n",
    "    losses_home=('away_win', 'sum'),\n",
    "    ties_home=('tie', 'sum'),\n",
    "    total_matches_home=('home_team', 'size')\n",
    ")\n",
    "\n",
    "# Aggregate stats for games played away for each team\n",
    "away_stats = df.groupby('away_team').agg(\n",
    "    wins_away=('away_win', 'sum'),\n",
    "    losses_away=('home_win', 'sum'),\n",
    "    ties_away=('tie', 'sum'),\n",
    "    total_matches_away=('away_team', 'size')\n",
    ")\n",
    "\n",
    "# Combine the home and away statistics\n",
    "country_stats = pd.concat([home_stats, away_stats], axis=1).fillna(0).astype(int)\n",
    "\n",
    "# Calculate the overall total wins, losses, ties, and matches\n",
    "country_stats['total_wins'] = country_stats['wins_home'] + country_stats['wins_away']\n",
    "country_stats['total_losses'] = country_stats['losses_home'] + country_stats['losses_away']\n",
    "country_stats['total_ties'] = country_stats['ties_home'] + country_stats['ties_away']\n",
    "country_stats['total_matches'] = country_stats['total_matches_home'] + country_stats['total_matches_away']\n",
    "\n",
    "# Format the final DataFrame\n",
    "country_stats = country_stats.reset_index().rename(columns={'index': 'country'})\n",
    "country_stats = country_stats.sort_values('total_matches', ascending=False)\n",
    "\n",
    "# Remove temporary columns from the original DataFrame\n",
    "df.drop(columns=['home_win', 'away_win', 'tie'], inplace=True)\n",
    "\n",
    "country_stats"
   ]
  },
