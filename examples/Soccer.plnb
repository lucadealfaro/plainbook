   "source": [
    "import matplotlib.pyplot as plt\n",
    "import numpy as np\n",
    "\n",
    "# Calculate total matches and win fractions\n",
    "country_stats['total_matches'] = country_stats['home_matches'] + country_stats['away_matches']\n",
    "country_stats['home_win_frac'] = country_stats['home_wins'] / country_stats['home_matches'].replace(0, np.nan)\n",
    "country_stats['away_win_frac'] = country_stats['away_wins'] / country_stats['away_matches'].replace(0, np.nan)\n",
    "\n",
    "# Get top 20 countries by total matches\n",
    "top20 = country_stats.nlargest(20, 'total_matches').sort_values('total_matches', ascending=True)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 8))\n",
    "\n",
    "y = np.arange(len(top20))\n",
    "bar_width = 0.35\n",
    "\n",
    "bars1 = ax.barh(y - bar_width/2, top20['home_win_frac'], bar_width, label='Home Win Fraction', color='steelblue')\n",
    "bars2 = ax.barh(y + bar_width/2, top20['away_win_frac'], bar_width, label='Away Win Fraction', color='coral')\n",
    "\n",
    "ax.set_yticks(y)\n",
    "ax.set_yticklabels(top20['country'])\n",
    "ax.set_xlabel('Fraction of Matches Won')\n",
    "ax.set_title('Home vs Away Win Fraction for Top 20 Countries (by Total Matches)')\n",
    "ax.legend()\n",
    "ax.set_xlim(0, 1)\n",
    "ax.axvline(x=0.5, color='gray', linestyle='--', linewidth=0.8, alpha=0.7)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  }
 ],
