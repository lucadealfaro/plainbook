   "source": [
    "# Create a dataset with match statistics per country\n",
    "home_stats = df.groupby('home_team').agg(\n",
    "    home_matches=('home_team', 'count'),\n",
    "    home_wins=('home_score', lambda x: ((x > df.loc[x.index, 'away_score'])).sum())\n",
    ").reset_index().rename(columns={'home_team': 'country'})\n",
    "\n",
    "away_stats = df.groupby('away_team').agg(\n",
    "    away_matches=('away_team', 'count'),\n",
    "    away_wins=('away_score', lambda x: ((x > df.loc[x.index, 'home_score'])).sum())\n",
    ").reset_index().rename(columns={'away_team': 'country'})\n",
    "\n",
    "country_stats = pd.merge(home_stats, away_stats, on='country', how='outer').fillna(0)\n",
    "country_stats[['home_matches', 'home_wins', 'away_matches', 'away_wins']] = country_stats[['home_matches', 'home_wins', 'away_matches', 'away_wins']].astype(int)\n",
    "country_stats"
   ]
  },
